<% layout('layout') -%>

<div class="wrapper mt-10">
  <% if (message.length > 0) { %>
  <div class="alert alert-success alert-dismissable">
    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
      <span aria-hidden="true">&times;</span>
    </button>
    <%= message %>
  </div>
  <% } %>
  <div class="row">
    <div class="col-lg-8">
      <% for (var i = 0; i < foundCart.items.length; i++) { %>
      <div class="list-group">
        <span class="list-group-item">
          <div class="row align-items-center">
            <div class="col-md-3 text-center">
              <img class="img-fluid cart-item-image" src="<%= foundCart.items[i].item.image %>" />
            </div>
            <div class="col-md-5">
              <h5 class="mb-2"><%= foundCart.items[i].item.name %></h5>
              <p class="text-muted mb-1">Quantity: <%= foundCart.items[i].quantity %></p>
            </div>
            <div class="col-md-4 text-md-right">
              <p class="searched-product__price mb-2">Rs <%= foundCart.items[i].price %></p>
              <form method="post" action="/remove">
                <input type="hidden" name="item" value="<%= foundCart.items[i]._id %>" />
                <input type="hidden" name="price" value="<%= foundCart.items[i].price %>" />
                <button class="btn btn-outline-primary btn-sm" type="submit">Remove</button>
              </form>
            </div>
          </div>
        </span>
      </div>
      <% } %>
    </div>

    <div class="col-md-4">
      <% if (foundCart.total > 0) { %>
      <div class="cart-summary-card">
        <div class="card-header-custom">
          <i class="fas fa-receipt"></i> Order Summary
        </div>
        <h6>SubTotal: Rs <span class="totalPrice"><%= foundCart.total %></span></h6>
        <h6>Shipping: <span class="text-success">FREE</span></h6>
        <h6>GST: 0%</h6>
        <hr />
        <div class="d-flex justify-content-between align-items-center">
          <span class="h6 mb-0">Total</span>
          <span class="total-amount">Rs <%= foundCart.total %></span>
        </div>
        <input type="hidden" value="<%= foundCart.total %>" />
        <a class="btn btn-info btn-block mt-4" href="/shipping-form">
          <i class="fas fa-lock"></i> Proceed to Checkout
        </a>
      </div>
      <% } else { %>
    </div>
  </div>
  <div class="empty-state">
    <img src="assets/no-item-found-here.png" alt="no-items-logo" />
    <h4>Your cart is empty</h4>
    <p class="text-muted">Browse our products and add items to your cart</p>
    <a class="btn btn-primary btn-round" href="/products">Browse Products</a>
  </div>
  <% } %>
</div>
