<% layout('layout') -%>
<div class="wrapper mt-10">
  <div class="mb-5">
    <% if (products.length == 0) { %>
    <div class="empty-state">
      <img src="/assets/no-item-found-here.png" alt="no-product-logo" />
      <h4>No products found in this category</h4>
      <a class="btn btn-primary btn-round" href="/">Browse All Products</a>
    </div>
    <% } else { %>

    <h4 class="product-heading mb-5">
      <i class="fas fa-folder-open"></i> <%= products[0].category.name %>
      <small class="text-muted d-block" style="font-size: 0.9rem;"><%= totalProducts %> products found</small>
    </h4>

    <div class="category__products">
      <% for (var i=0; i< products.length; i++) { %>
      <div class="category__product">
        <img class="img-fluid" src="../<%= products[i].image %>" alt="" />
        <h2><%= products[i].name %></h2>
        <p class="searched-product__price mb-0">
          <i class="fas fa-rupee-sign"></i> <%= products[i].price %>
        </p>
        <a class="btn btn-sm btn-outline-info" href="/product/<%= products[i]._id %>">
          <i class="fas fa-eye"></i> Show More
        </a>
      </div>
      <% } %>
    </div>

    <% if (totalPages > 1) { %>
    <nav class="mt-5">
      <ul class="pagination justify-content-center">
        <li class="page-item <%= currentPage <= 1 ? 'disabled' : '' %>">
          <a class="page-link" href="/products/<%= categoryId %>?page=<%= currentPage - 1 %>">&laquo; Prev</a>
        </li>
        <% for (var p = 1; p <= totalPages; p++) { %>
        <li class="page-item <%= p === currentPage ? 'active' : '' %>">
          <a class="page-link" href="/products/<%= categoryId %>?page=<%= p %>"><%= p %></a>
        </li>
        <% } %>
        <li class="page-item <%= currentPage >= totalPages ? 'disabled' : '' %>">
          <a class="page-link" href="/products/<%= categoryId %>?page=<%= currentPage + 1 %>">Next &raquo;</a>
        </li>
      </ul>
    </nav>
    <% } %>
    <% } %>
  </div>
</div>