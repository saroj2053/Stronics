<% layout('layout') -%>

<div class="jumbotron mt-3">
    <div class="container text-center">
        <h1>Find Your Favorite Product</h1>
        <p>Discover amazing products from our curated collection</p>
        <div class="row justify-content-center">
            <div class="col-md-6">
                <form method="POST" class="input-group">
                    <input type="text" id="search" class="form-control input-lg" name="search_item" placeholder="Search for a Product...">
                    <div class="input-group-append">
                        <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i></button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<h2 class="text-center product-heading my-4">
    <i class="fas fa-box-open"></i> Our Products
    <small class="text-muted d-block" style="font-size: 0.9rem;"><%= totalProducts %> products found</small>
</h2>
<div class="containerWrapper mb-5">
    <div class="productsWrapper">
    <% for (var i=0; i< products.length; i++) { %>
        <div class="productContainer">
            <span class="product__category">
               <%= products[i].category.name %>
            </span>
            <img src="<%= products[i].image %>" alt="">
            <h2>
                <%= products[i].name.substring(0, 35) %> ...
            </h2>
            <p class="searched-product__price">
                <i class="fas fa-rupee-sign"></i> <strong><%= products[i].price %></strong>
            </p>
            <a class="btn btn-outline-info btn-round more-info" href="/product/<%= products[i]._id %>">
                <i class="fas fa-eye"></i> View Details
            </a>
        </div>
    <% } %>
    </div>

    <% if (totalPages > 1) { %>
    <nav class="mt-5">
        <ul class="pagination justify-content-center">
            <li class="page-item <%= currentPage <= 1 ? 'disabled' : '' %>">
                <a class="page-link" href="/?page=<%= currentPage - 1 %>">&laquo; Prev</a>
            </li>
            <% for (var p = 1; p <= totalPages; p++) { %>
            <li class="page-item <%= p === currentPage ? 'active' : '' %>">
                <a class="page-link" href="/?page=<%= p %>"><%= p %></a>
            </li>
            <% } %>
            <li class="page-item <%= currentPage >= totalPages ? 'disabled' : '' %>">
                <a class="page-link" href="/?page=<%= currentPage + 1 %>">Next &raquo;</a>
            </li>
        </ul>
    </nav>
    <% } %>
</div>